{
  "name": "bgs-invoice-backend",
  "version": "1.0.0",
  "description": "BGS GST Invoice Generator API",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "node --watch server.js",
    "postinstall": "node scripts/prisma-run.js generate",
    "db:generate": "node scripts/prisma-run.js generate",
    "db:push": "node scripts/prisma-run.js db push",
    "db:migrate": "node scripts/prisma-run.js migrate deploy",
    "db:studio": "node scripts/prisma-run.js studio",
    "db:test": "node scripts/test-db.js"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "prisma": "^6.5.0"
  }
}
