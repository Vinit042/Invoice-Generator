NODE_ENV=production

PORT=3000

# MySQL — use the credentials from Hostinger hPanel > Databases > MySQL Databases
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_hostinger_db_username
MYSQL_PASSWORD=your_hostinger_db_password
MYSQL_DATABASE=your_hostinger_db_name

# JWT — generate a strong random string (e.g. openssl rand -hex 32)
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# Uploads — absolute path to the uploads folder on the server
# Replace "yourusername" with your actual Hostinger cPanel username
UPLOAD_DIR=/home/yourusername/bgs_invoice/uploads
